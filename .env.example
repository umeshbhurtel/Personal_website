# ── Admin Panel ───────────────────────────────────────
# Password to log in to /admin
# Can be plain text (dev) or a bcrypt hash (production)
ADMIN_PASSWORD=your_admin_password_here

# Secret key used to sign admin session cookies
# Generate with: openssl rand -base64 32
SESSION_SECRET=your_random_secret_key_here

# ── Contact Form (optional) ───────────────────────────
# Used by the contact form API to send emails via nodemailer
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
CONTACT_TO=your_email@gmail.com
