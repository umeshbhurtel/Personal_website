# ── Dependencies ──────────────────────────────────────
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# ── Next.js ───────────────────────────────────────────
/.next/
/out/
/build

# ── Testing ───────────────────────────────────────────
/coverage

# ── Environment variables (never commit secrets) ──────
.env*.local
.env

# ── Private / personal data files ────────────────────
/data/contacts.json
/data/newsletter.json
/data/case-studies.json

# ── Uploaded user files (CV, PDFs) ───────────────────
/public/uploads/cv/*
!/public/uploads/cv/.gitkeep
/public/uploads/case-studies/*
!/public/uploads/case-studies/.gitkeep

# ── Editor / OS / tooling ─────────────────────────────
.DS_Store
*.pem
.vscode/
.claude/
*.tsbuildinfo
next-env.d.ts

# ── Debug logs ────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Vercel ────────────────────────────────────────────
.vercel
